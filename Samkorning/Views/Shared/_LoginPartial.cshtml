@using Microsoft.AspNetCore.Identity
@using Samkorning.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        <li class="nav-item">
            <a class="nav-link text-light" asp-controller="Profile" asp-action="Edit">
                <i class="bi bi-person-circle me-1"></i>
                @if (string.IsNullOrEmpty(user?.FamilyName))
                {
                    <span class="text-warning">Ange namn</span>
                }
                else
                {
                    @user.FamilyName
                }
            </a>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post">
                <button type="submit" class="nav-link btn btn-link text-light">
                    <i class="bi bi-box-arrow-right me-1"></i>Logga ut
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-box-arrow-in-right me-1"></i>Logga in
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus me-1"></i>Registrera
            </a>
        </li>
    }
</ul>
