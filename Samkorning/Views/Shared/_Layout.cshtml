<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Falu HK F14</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --hk-black: #111111;
            --hk-yellow: #f5c400;
            --hk-yellow-dark: #d4a900;
            --hk-gray: #2a2a2a;
        }

        body {
            background-color: #f4f4f4;
        }

        /* Navbar */
        .navbar {
            background-color: var(--hk-black) !important;
            border-bottom: 3px solid var(--hk-yellow);
        }
        .navbar-brand {
            color: var(--hk-black) !important;
            background-color: var(--hk-yellow);
            font-weight: 900;
            font-size: 1.1rem;
            padding: 6px 14px;
            border-radius: 2px;
            letter-spacing: 0.5px;
        }
        .navbar-brand:hover {
            background-color: var(--hk-yellow-dark);
        }
        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--hk-yellow) !important;
        }

        /* Buttons */
        .btn-hk {
            background-color: var(--hk-yellow);
            color: var(--hk-black);
            border: none;
            font-weight: 700;
        }
        .btn-hk:hover {
            background-color: var(--hk-yellow-dark);
            color: var(--hk-black);
        }
        .btn-outline-hk {
            border: 2px solid var(--hk-yellow);
            color: var(--hk-black);
            font-weight: 600;
        }
        .btn-outline-hk:hover {
            background-color: var(--hk-yellow);
            color: var(--hk-black);
        }

        /* Cards */
        .card-event { border-left: 4px solid var(--hk-yellow); }
        .card { border-radius: 6px; }

        /* Feature cards on event detail */
        .feature-card {
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            transition: border-color 0.15s;
        }
        .feature-card:hover { border-color: var(--hk-yellow); }
        .feature-card .feature-icon {
            font-size: 2.5rem;
            color: var(--hk-yellow);
        }

        /* Status badges */
        .badge-driver { background-color: var(--hk-black); color: white; }
        .obligation-ok { color: #198754; }
        .obligation-warn { color: #dc3545; }

        /* Footer */
        footer {
            background-color: var(--hk-black);
            border-top: 3px solid var(--hk-yellow);
            color: rgba(255,255,255,0.7);
            margin-top: 3rem;
            padding: 1.5rem 0;
        }
        footer strong { color: var(--hk-yellow); }

        /* Table dark header */
        .table-hk thead { background-color: var(--hk-black); color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">FALU HK F14</a>
            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" style="filter:invert(1)"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Events" asp-action="Index">
                                <i class="bi bi-calendar-event me-1"></i>Matcher
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Events" asp-action="Summary">
                                <i class="bi bi-bar-chart-line me-1"></i>Statistik
                            </a>
                        </li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-gear me-1"></i>Admin
                            </a>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <footer>
        <div class="container text-center">
            <strong>Falu HK F14</strong> &nbsp;&mdash;&nbsp;
            <small>Handboll med hjärta sedan 2008 &copy; @DateTime.Now.Year</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
