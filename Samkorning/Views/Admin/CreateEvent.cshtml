@model Samkorning.Models.CompetitionEvent
@{
    ViewData["Title"] = "Ny match";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <a asp-controller="Admin" asp-action="Index" class="text-muted text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Tillbaka
        </a>
        <h3 class="mt-2">Lägg till match</h3>

        <div class="card mt-4">
            <div class="card-body">
                <form asp-action="CreateEvent" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="T.ex. SM-kval Linköping" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label fw-semibold"></label>
                        <input asp-for="Date" class="form-control" type="date" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold"></label>
                        <input asp-for="Location" class="form-control" placeholder="T.ex. Linköping ishall" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RequiredDrivers" class="form-label fw-semibold"></label>
                        <input asp-for="RequiredDrivers" class="form-control" type="number" min="1" max="20" />
                        <div class="form-text">Hur många bilar behövs?</div>
                        <span asp-validation-for="RequiredDrivers" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Extra info, samlingstid etc."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-hk w-100">
                        <i class="bi bi-check-circle me-2"></i>Skapa match
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
