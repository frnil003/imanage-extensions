@model Samkorning.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin";
    var sv = new System.Globalization.CultureInfo("sv-SE");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear me-2"></i>Adminpanel</h2>
    <div class="d-flex gap-2">
        <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-people me-2"></i>Hantera användare
        </a>
        <a asp-controller="Admin" asp-action="CreateEvent" class="btn btn-hk">
            <i class="bi bi-plus-circle me-2"></i>Lägg till match
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold" style="color:#003366">@Model.TotalEvents</div>
                <div class="text-muted small">Totalt matcher</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold" style="color:#003366">@Model.UpcomingEvents</div>
                <div class="text-muted small">Kommande</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold @(Model.EventSummaries.Count(e => e.NeedsMoreDrivers) > 0 ? "text-danger" : "text-success")">
                    @Model.EventSummaries.Count(e => e.NeedsMoreDrivers)
                </div>
                <div class="text-muted small">Behöver förare</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="fs-2 fw-bold @(Model.FamilyObligations.Count(f => !f.MetObligation) > 0 ? "text-warning" : "text-success")">
                    @Model.FamilyObligations.Count(f => !f.MetObligation)
                </div>
                <div class="text-muted small">Ej uppfyllt krav</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <h5 class="mb-3">Matcher</h5>
        @if (!Model.EventSummaries.Any())
        {
            <div class="alert alert-info">Inga matcher inlagda.</div>
        }
        <div class="list-group">
            @foreach (var s in Model.EventSummaries)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1">@s.Event.Name</h6>
                            <small class="text-muted">
                                @s.Event.Date.ToString("d MMMM yyyy", sv)
                                @if (!string.IsNullOrEmpty(s.Event.Location))
                                {
                                    <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>@s.Event.Location</span>
                                }
                            </small>
                        </div>
                        <div class="d-flex gap-1 align-items-center">
                            <span class="badge @(s.NeedsMoreDrivers ? "bg-warning text-dark" : "bg-success")">
                                @s.DriverCount / @s.RequiredDrivers bilar
                            </span>
                            <a asp-controller="Admin" asp-action="EventBookings" asp-route-id="@s.Event.Id"
                               class="btn btn-sm btn-outline-secondary ms-1" title="Hantera bokningar">
                                <i class="bi bi-people"></i>
                            </a>
                            <a asp-controller="Admin" asp-action="EditEvent" asp-route-id="@s.Event.Id"
                               class="btn btn-sm btn-outline-secondary" title="Redigera">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-controller="Admin" asp-action="DeleteEvent" method="post"
                                  onsubmit="return confirm('Ta bort matchen och alla bokningar?')">
                                <input type="hidden" name="id" value="@s.Event.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Ta bort">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <h5 class="mb-3">
            Familjekrav
            <small class="text-muted fw-normal fs-6">(min @Model.MinDriverObligation körningar)</small>
        </h5>
        @if (!Model.FamilyObligations.Any())
        {
            <div class="alert alert-info">Inga familjer registrerade.</div>
        }
        <div class="list-group">
            @foreach (var f in Model.FamilyObligations)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">@f.FamilyName</div>
                        <small class="text-muted">@f.Email</small>
                    </div>
                    <div class="text-end">
                        <span class="badge @(f.MetObligation ? "bg-success" : (f.DriverCount > 0 ? "bg-warning text-dark" : "bg-danger"))">
                            @f.DriverCount / @Model.MinDriverObligation körn.
                        </span>
                        @if (f.MetObligation)
                        {
                            <div><i class="bi bi-check-circle-fill obligation-ok small"></i></div>
                        }
                        else
                        {
                            <div><i class="bi bi-exclamation-circle obligation-warn small"></i></div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
