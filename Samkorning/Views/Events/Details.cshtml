@model Samkorning.Models.ViewModels.EventDetailViewModel
@{
    ViewData["Title"] = Model.Event.Name;
    var sv = new System.Globalization.CultureInfo("sv-SE");
}

<a asp-controller="Events" asp-action="Index" class="text-muted text-decoration-none">
    <i class="bi bi-arrow-left me-1"></i>Tillbaka
</a>

<div class="py-3 px-4 mt-2 mb-4 rounded" style="background:#111; color:white;">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h2 class="fw-black mb-1" style="color:#f5c400">@Model.Event.Name</h2>
            <p class="mb-0 text-white-50">
                <i class="bi bi-calendar3 me-2"></i>@Model.Event.Date.ToString("dddd d MMMM yyyy", sv)
                @if (!string.IsNullOrEmpty(Model.Event.Location))
                {
                    <span class="ms-3"><i class="bi bi-geo-alt me-1"></i>@Model.Event.Location</span>
                }
            </p>
            @if (!string.IsNullOrEmpty(Model.Event.Description))
            {
                <p class="mt-2 text-white-50 small mb-0">@Model.Event.Description</p>
            }
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="EventBookings" asp-route-id="@Model.Event.Id"
               class="btn btn-sm btn-hk">
                <i class="bi bi-gear me-1"></i>Administrera
            </a>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Aktiviteter -->
    <div class="col-md-6">
        <div class="card feature-card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-clipboard-check feature-icon me-3" style="font-size:1.8rem"></i>
                    <div>
                        <h5 class="fw-bold mb-0">Aktiviteter</h5>
                        <small class="text-muted">Sekretariat, kiosk, matchvärd m.m.</small>
                    </div>
                </div>

                @if (!Model.Event.Activities.Any())
                {
                    <p class="text-muted small">Inga aktiviteter inlagda ännu.</p>
                }
                else
                {
                    var activities = Model.Event.Activities
                        .OrderBy(a => a.Name)
                        .ThenBy(a => a.TimeSlot);
                    foreach (var a in activities)
                    {
                        <div class="mb-1 d-flex justify-content-between align-items-baseline">
                            <div>
                                <span class="fw-semibold small">@a.Name</span>
                                @if (!string.IsNullOrEmpty(a.TimeSlot))
                                {
                                    <span class="badge bg-light text-dark border ms-1" style="font-size:0.7rem">
                                        <i class="bi bi-clock me-1"></i>@a.TimeSlot
                                    </span>
                                }
                            </div>
                            <span class="text-muted small ms-2 text-nowrap">
                                @a.Signups.Count / @a.MaxParticipants anmälda
                            </span>
                        </div>
                    }
                }

                <a asp-controller="Activities" asp-action="Event" asp-route-eventId="@Model.Event.Id"
                   class="btn btn-hk mt-3 w-100">
                    <i class="bi bi-clipboard-check me-2"></i>
                    @(Model.Event.Activities.Any() ? "Visa och anmäl dig" : "Öppna aktiviteter")
                </a>
            </div>
        </div>
    </div>

    <!-- Samkörning -->
    <div class="col-md-6">
        <div class="card feature-card h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-car-front feature-icon me-3" style="font-size:1.8rem"></i>
                    <div>
                        <h5 class="fw-bold mb-0">Samkörning</h5>
                        <small class="text-muted">Transport till matchen</small>
                    </div>
                </div>

                @{
                    int driverCount = Model.Event.Bookings.Count(b => b.Role == BookingRole.Driver);
                    int required = Model.Event.RequiredDrivers;
                }

                @if (!Model.Event.Bookings.Any())
                {
                    <p class="text-muted small">Ingen samkörning anordnad ännu.</p>
                }
                else
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>Förare</span>
                            <span class="@(driverCount >= required ? "text-success fw-bold" : "text-warning fw-bold")">
                                @driverCount / @required
                            </span>
                        </div>
                        <div class="progress" style="height:6px">
                            <div class="progress-bar @(driverCount >= required ? "bg-success" : "")"
                                 style="width:@(Math.Min(100, driverCount * 100 / required))%; background-color:@(driverCount >= required ? "" : "#f5c400")">
                            </div>
                        </div>
                    </div>

                    @if (Model.MyBooking != null)
                    {
                        <div class="mt-2">
                            <span class="badge bg-dark">
                                Du: @(Model.MyBooking.Role == BookingRole.Driver ? "Förare" : "Passagerare")
                            </span>
                        </div>
                    }
                }

                <a asp-controller="Events" asp-action="Carpooling" asp-route-id="@Model.Event.Id"
                   class="btn btn-outline-dark mt-3 w-100">
                    <i class="bi bi-car-front me-2"></i>
                    @(Model.Event.Bookings.Any() ? "Visa samkörning" : "Starta samkörning")
                </a>
            </div>
        </div>
    </div>
</div>
