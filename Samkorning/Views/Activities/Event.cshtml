@model Samkorning.Models.ViewModels.EventActivitiesViewModel
@{
    ViewData["Title"] = "Aktiviteter – " + Model.Event.Name;
    var sv = new System.Globalization.CultureInfo("sv-SE");
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.Event.Id" class="text-muted text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Tillbaka till matchen
        </a>
        <h2 class="mt-1"><i class="bi bi-clipboard-check me-2"></i>Aktiviteter</h2>
        <p class="text-muted mb-0">
            <strong>@Model.Event.Name</strong> &mdash;
            @Model.Event.Date.ToString("dddd d MMMM yyyy", sv)
        </p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Admin" asp-action="CreateActivity" asp-route-eventId="@Model.Event.Id" class="btn btn-hk">
            <i class="bi bi-plus-circle me-2"></i>Lägg till aktivitet
        </a>
    }
</div>

@if (!Model.Groups.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Inga aktiviteter har lagts till för den här matchen ännu.
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="CreateActivity" asp-route-eventId="@Model.Event.Id" class="alert-link ms-1">
                Lägg till den första aktiviteten →
            </a>
        }
    </div>
}

@foreach (var group in Model.Groups)
{
    <div class="mb-4">
        <h5 class="mb-3">
            <i class="bi bi-person-workspace me-2 text-secondary"></i>@group.Name
        </h5>
        <div class="row g-3">
            @foreach (var row in group.Activities)
            {
                var a = row.Activity;
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(row.SignedUp ? "border-success" : (a.IsFull ? "border-secondary opacity-75" : ""))">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    @if (!string.IsNullOrEmpty(a.TimeSlot))
                                    {
                                        <span class="badge bg-light text-dark border mb-1">
                                            <i class="bi bi-clock me-1"></i>@a.TimeSlot
                                        </span>
                                    }
                                    <h6 class="mb-0">@a.Name</h6>
                                </div>
                                @if (row.SignedUp)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Anmäld
                                    </span>
                                }
                                else if (a.IsFull)
                                {
                                    <span class="badge bg-secondary">Fullbokad</span>
                                }
                            </div>

                            @if (!string.IsNullOrEmpty(a.Description))
                            {
                                <p class="text-muted small mb-2">@a.Description</p>
                            }

                            <div class="mb-3">
                                @for (int i = 0; i < a.MaxParticipants; i++)
                                {
                                    if (i < a.Signups.Count)
                                    {
                                        var signup = a.Signups.ElementAt(i);
                                        <span class="badge @(signup.UserId == Model.CurrentUserId ? "bg-success" : "bg-primary") me-1 mb-1">
                                            <i class="bi bi-person-fill me-1"></i>@signup.User.FamilyName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border me-1 mb-1">
                                            <i class="bi bi-person me-1"></i>Ledig plats
                                        </span>
                                    }
                                }
                            </div>

                            @if (Model.Event.IsUpcoming)
                            {
                                if (row.SignedUp)
                                {
                                    <form asp-controller="Activities" asp-action="Remove" method="post">
                                        <input type="hidden" name="signupId" value="@row.MySignupId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                                onclick="return confirm('Avanmäl dig från @a.Name?')">
                                            <i class="bi bi-x-circle me-1"></i>Avanmäl mig
                                        </button>
                                    </form>
                                }
                                else if (!a.IsFull)
                                {
                                    <form asp-controller="Activities" asp-action="SignUp" method="post">
                                        <input type="hidden" name="activityId" value="@a.Id" />
                                        <button type="submit" class="btn btn-sm btn-hk w-100">
                                            <i class="bi bi-plus-circle me-1"></i>Anmäl mig
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary w-100" disabled>
                                        <i class="bi bi-lock me-1"></i>Fullbokad
                                    </button>
                                }
                            }
                        </div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="card-footer d-flex justify-content-end gap-2 py-2">
                                <a asp-controller="Admin" asp-action="EditActivity" asp-route-id="@a.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-controller="Admin" asp-action="DeleteActivity" method="post"
                                      onsubmit="return confirm('Ta bort aktiviteten och alla anmälningar?')">
                                    <input type="hidden" name="id" value="@a.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
